# Normalize line endings so the repo works across OSes.
# Default: detect text, store/checkout with LF.
* text=auto eol=lf

# Python and shell must be LF (CRLF breaks shebang/exec on Linux/macOS).
*.py text eol=lf
*.sh text eol=lf

# Windows scripts want CRLF.
*.bat text eol=crlf
*.vbs text eol=crlf
*.ps1 text eol=crlf

# Binaries.
*.session binary
*.png binary
