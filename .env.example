# ---------------------------------------------------------------------------
# Beeper -> Poke Bridge configuration
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Who the bridge triages for. Used in the gatekeeper prompt and in the handoff
# it sends to Poke. Use your first name or how you'd refer to yourself.
OWNER_NAME=YourName

# --- Beeper Desktop ---------------------------------------------------------
# Get this from Beeper Desktop: Settings -> Developer / Desktop API -> copy token.
# Beeper Desktop must be running for the bridge to connect.
BEEPER_TOKEN=

# Beeper's local API host/port. Defaults are correct for a standard install;
# only change these if you've moved Beeper's API or run it behind a proxy.
# BEEPER_HOST=localhost
# BEEPER_API_PORT=23373

# Beeper room ID of YOUR iMessage chat with Poke. The bridge ignores this chat so
# it never feeds Poke's own messages back into Poke. To find it: open the Poke
# chat in Beeper and copy the chat/room ID (looks like !xxxxxxxx:beeper.local).
# Optional but strongly recommended.
POKE_BEEPER_CHAT_ID=

# --- Handoff transport: how the bridge reaches Poke -------------------------
# Choose how the bridge delivers handoffs to Poke:
#   imessage (default) -> macOS Messages app (AppleScript); macOS only, no login.
#   telegram           -> a Telegram user session messages the Poke bot.
HANDOFF_TRANSPORT=imessage

# iMessage transport target for Poke. Two forms:
#   - a phone number / email (Poke's iMessage number, the default), OR
#   - a chat GUID to hit an existing thread directly, e.g. Apple Messages for
#     Business (AMB) "Poke" which has no phone number:
#       POKE_IMESSAGE_HANDLE=iMessage;-;urn:biz:6e67a89b-cd37-4c25-ad21-1b942f2a0f14
#     (find it: sqlite3 chat.db "SELECT guid FROM chat WHERE display_name='Poke';")
POKE_IMESSAGE_HANDLE=+16503347837

# Telegram transport (only used when HANDOFF_TRANSPORT=telegram).
# Create an app at https://my.telegram.org -> API development tools, then run
# `python bridge.py --login` once to create the session before running.
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# POKE_TELEGRAM_USERNAME=interaction_poke_bot
# TELEGRAM_SESSION_NAME=telegram-poke-bridge

# Optional: cap handoff length in characters (default 4000).
# MAX_HANDOFF_MESSAGE=4000

# --- LLM provider for the gatekeeper ----------------------------------------
# Two ways to power the gate:
#
# A) ChatGPT subscription via Codex OAuth (no API key, no per-call billing):
#      install Codex CLI, run `codex login` once. Leave LLM_API_KEY blank and
#      LLM_PROVIDER=auto (default) -- the bridge detects ~/.codex/auth.json and
#      uses your subscription through the Responses API. Note: this is an
#      undocumented endpoint OpenAI tolerates for third-party use; it can change.
#   LLM_PROVIDER=auto            # auto | codex | openai
#   CODEX_MODEL=gpt-5.4-mini     # override if the default model name rotates
#
# B) A normal OpenAI-compatible API key (OpenAI, OpenRouter, local server...):
#      set LLM_API_KEY (and LLM_BASE_URL if not OpenAI). Setting a key makes
#      `auto` prefer it over Codex.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
GATEKEEPER_MODEL=gpt-5.4-mini

# --- Optional ---------------------------------------------------------------
# BRIDGE_LOG_FILE=bridge.log
