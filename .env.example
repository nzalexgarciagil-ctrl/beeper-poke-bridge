# ---------------------------------------------------------------------------
# Beeper -> Poke Bridge configuration
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Who the bridge triages for. Used in the gatekeeper prompt and in the handoff
# it sends to Poke. Use your first name or how you'd refer to yourself.
OWNER_NAME=YourName

# --- Beeper Desktop ---------------------------------------------------------
# Get this from Beeper Desktop: Settings -> Developer / Desktop API -> copy token.
# Beeper Desktop must be running for the bridge to connect.
BEEPER_TOKEN=

# Beeper's local API host/port. Defaults are correct for a standard install;
# only change these if you've moved Beeper's API or run it behind a proxy.
# BEEPER_HOST=localhost
# BEEPER_API_PORT=23373

# Beeper room ID of YOUR Telegram chat with the Poke bot. The bridge ignores this
# chat so it never feeds Poke's own messages back into Poke. To find it: open the
# Poke chat in Beeper and copy the chat/room ID (looks like
# !xxxxxxxx:beeper.local). Optional but strongly recommended.
POKE_BEEPER_CHAT_ID=

# --- Telegram (the account that delivers handoffs to the Poke bot) ----------
# Create an app at https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# The Poke bot username on Telegram (default is correct for most users).
# POKE_TELEGRAM_USERNAME=interaction_poke_bot
# Run `python bridge.py --login` once to create the session before running.

# --- LLM provider for the gatekeeper (OpenAI-compatible) --------------------
# Any OpenAI-compatible endpoint works (OpenAI, OpenRouter, a local server...).
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
GATEKEEPER_MODEL=gpt-4o-mini

# --- Optional ---------------------------------------------------------------
# BRIDGE_LOG_FILE=bridge.log
# TELEGRAM_SESSION_NAME=telegram-poke-bridge
